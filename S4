-- // CONFIGURACIÓN "ACUSADO NINJA HUB"
local Settings = {
    HeadSize = 10,
    HitboxEnabled = false,
    ESPEnabled = false,
    TracersEnabled = false,
    ShowWeapon = false,
    Color = Color3.fromRGB(0, 255, 0),
    Rainbow = false
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Mouse = LocalPlayer:GetMouse()

-- // INTERFAZ (ANCHA, X, OPEN Y TOGGLE)
local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
local main = Instance.new("Frame", sg)
main.Name = "AcusadoMain"; main.Size = UDim2.new(0, 350, 0, 450); main.Position = UDim2.new(0.5, -175, 0.3, 0)
main.BackgroundColor3 = Color3.fromRGB(10, 10, 10); main.BorderSizePixel = 0; main.Active = true; main.Draggable = true 

local stroke = Instance.new("UIStroke", main); stroke.Color = Settings.Color; stroke.Thickness = 3

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 50); title.Text = "ACUSADO NINJA HUB"; title.TextColor3 = Settings.Color
title.BackgroundColor3 = Color3.fromRGB(20, 20, 20); title.TextSize = 24; title.Font = Enum.Font.GothamBold

local closeBtn = Instance.new("TextButton", main)
closeBtn.Size = UDim2.new(0, 45, 0, 45); closeBtn.Position = UDim2.new(1, -45, 0, 0); closeBtn.BackgroundTransparency = 1
closeBtn.Text = "X"; closeBtn.TextColor3 = Color3.new(1, 0, 0); closeBtn.TextSize = 26; closeBtn.Font = Enum.Font.GothamBold

local openBtn = Instance.new("TextButton", sg)
openBtn.Size = UDim2.new(0, 90, 0, 35); openBtn.Position = UDim2.new(0, 10, 0.5, 0)
openBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 15); openBtn.Text = "OPEN"; openBtn.TextColor3 = Color3.new(1, 1, 1); openBtn.Visible = false
local oStroke = Instance.new("UIStroke", openBtn); oStroke.Color = Settings.Color; Instance.new("UICorner", openBtn)

closeBtn.MouseButton1Click:Connect(function() main.Visible = false; openBtn.Visible = true end)
openBtn.MouseButton1Click:Connect(function() main.Visible = true; openBtn.Visible = false end)
UserInputService.InputBegan:Connect(function(i, p) if not p and i.KeyCode == Enum.KeyCode.V then main.Visible = not main.Visible if main.Visible then openBtn.Visible = false end end end)

local function createBtn(pos, text)
    local btn = Instance.new("TextButton", main)
    btn.Size = UDim2.new(0, 320, 0, 35); btn.Position = pos; btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    btn.TextColor3 = Color3.new(1, 1, 1); btn.Text = text; btn.Font = Enum.Font.GothamBold; btn.TextSize = 14
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4); return btn
end

-- TUS OPCIONES (SIN TOCAR)
local bHitbox = createBtn(UDim2.new(0, 15, 0, 60), "Hitbox: OFF")
local sizeInput = Instance.new("TextBox", main)
sizeInput.Size = UDim2.new(0, 320, 0, 35); sizeInput.Position = UDim2.new(0, 15, 0, 100)
sizeInput.BackgroundColor3 = Color3.fromRGB(35, 35, 35); sizeInput.TextColor3 = Color3.new(1, 1, 1)
sizeInput.PlaceholderText = "Hitbox Size"; sizeInput.Text = "10"; sizeInput.Font = Enum.Font.GothamBold; Instance.new("UICorner", sizeInput)

local bESP = createBtn(UDim2.new(0, 15, 0, 140), "ESP Box (Outline): OFF")
local bTracers = createBtn(UDim2.new(0, 15, 0, 180), "Tracers (Top): OFF")
local bTool = createBtn(UDim2.new(0, 15, 0, 220), "Get Click Delete")
local bRainbow = createBtn(UDim2.new(0, 15, 0, 260), "Modo Rainbow: OFF")
local bColor = createBtn(UDim2.new(0, 15, 0, 300), "Cambiar Color Manual")
local bWeapon = createBtn(UDim2.new(0, 15, 0, 340), "Show Weapon: OFF")

sizeInput.FocusLost:Connect(function() Settings.HeadSize = tonumber(sizeInput.Text) or 10 end)
bHitbox.MouseButton1Click:Connect(function() Settings.HitboxEnabled = not Settings.HitboxEnabled; bHitbox.Text = "Hitbox: "..(Settings.HitboxEnabled and "ON" or "OFF") end)
bESP.MouseButton1Click:Connect(function() Settings.ESPEnabled = not Settings.ESPEnabled; bESP.Text = "ESP Box: "..(Settings.ESPEnabled and "ON" or "OFF") end)
bTracers.MouseButton1Click:Connect(function() Settings.TracersEnabled = not Settings.TracersEnabled; bTracers.Text = "Tracers (Top): "..(Settings.TracersEnabled and "ON" or "OFF") end)
bRainbow.MouseButton1Click:Connect(function() Settings.Rainbow = not Settings.Rainbow; bRainbow.Text = "Modo Rainbow: "..(Settings.Rainbow and "ON" or "OFF") end)
bColor.MouseButton1Click:Connect(function() Settings.Color = Color3.fromHSV(math.random(), 1, 1) end)
bWeapon.MouseButton1Click:Connect(function() Settings.ShowWeapon = not Settings.ShowWeapon; bWeapon.Text = "Show Weapon: "..(Settings.ShowWeapon and "ON" or "OFF") end)

bTool.MouseButton1Click:Connect(function()
    local tool = Instance.new("Tool"); tool.Name = "Click Delete"; tool.RequiresHandle = false; tool.Parent = LocalPlayer.Backpack
    tool.Activated:Connect(function() if Mouse.Target then Mouse.Target:Destroy() end end)
end)

-- // SEGURIDAD Y VISUALS
local function AddVisuals(plr)
    local box = Drawing.new("Square"); box.Thickness = 2; box.Filled = false; box.Visible = false
    local name = Drawing.new("Text"); name.Size = 14; name.Center = true; name.Outline = true; name.Visible = false
    local tracer = Drawing.new("Line"); tracer.Visible = false

    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") then
            local hrp = plr.Character.HumanoidRootPart
            local head = plr.Character.Head

            -- HITBOX SEGURA (ANTIBAN LOGIC)
            if Settings.HitboxEnabled then
                head.Size = Vector3.new(Settings.HeadSize, Settings.HeadSize, Settings.HeadSize)
                head.Transparency = 1
                head.CanCollide = false
                head.Massless = true
                -- Bloqueo de colisión para evitar detecciones del servidor
                if head:FindFirstChildOfClass("TouchTransmitter") then
                    head:FindFirstChildOfClass("TouchTransmitter"):Destroy()
                end
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                head.Transparency = 0
                head.CanCollide = true
            end

            -- ESP (DIBUJADO LOCAL SIN TOCAR EL JUEGO)
            local vector, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            if onScreen and Settings.ESPEnabled then
                local sizeY = (workspace.CurrentCamera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.5, 0)).Y - workspace.CurrentCamera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 4.5, 0)).Y)
                local sizeX = sizeY / 1.4
                box.Size = Vector2.new(sizeX, sizeY); box.Position = Vector2.new(vector.X - sizeX/2, vector.Y - sizeY/2)
                box.Color = Settings.Color; box.Visible = true
                
                if Settings.TracersEnabled then
                    name.Position = Vector2.new(vector.X, (vector.Y + sizeY/2) + 2)
                    name.Text = plr.Name .. (Settings.ShowWeapon and " ["..(plr.Character:FindFirstChildOfClass("Tool") and plr.Character:FindFirstChildOfClass("Tool").Name or "None").."]" or "")
                    name.Color = Color3.new(1,1,1); name.Visible = true
                    tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, 0)
                    tracer.To = Vector2.new(vector.X, vector.Y - sizeY/2); tracer.Color = Settings.Color; tracer.Visible = true
                else name.Visible = false; tracer.Visible = false end
            else box.Visible = false; name.Visible = false; tracer.Visible = false end
        else box.Visible = false; name.Visible = false; tracer.Visible = false end
    end)
end

-- INICIALIZACIÓN SEGURA
for _, v in pairs(Players:GetPlayers()) do if v ~= LocalPlayer then AddVisuals(v) end end
Players.PlayerAdded:Connect(function(v) AddVisuals(v) end)

-- RAINBOW (NO DETECTABLE POR SERVIDOR)
RunService.Heartbeat:Connect(function()
    if Settings.Rainbow then
        Settings.Color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
        stroke.Color = Settings.Color; oStroke.Color = Settings.Color; title.TextColor3 = Settings.Color
    end
end)
