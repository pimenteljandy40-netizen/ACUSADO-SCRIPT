-- ACUSADO NINJA HUB - MINI HITBOX EDITION
-- KEY: ACUSADO23 | ULTRA COMPACT

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "AcusadoMini_V2"

-- PANEL ULTRA COMPACTO (SÓLO HITBOX)
local Main = Instance.new("Frame", ScreenGui)
Main.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
Main.Size = UDim2.new(0, 200, 0, 150) -- Mucho más pequeño
Main.Position = UDim2.new(0.05, 0, 0.3, 0)
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)

local Stroke = Instance.new("UIStroke", Main)
Stroke.Thickness = 2.5
Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

-- TÍTULO CORTO
local Title = Instance.new("TextLabel", Main)
Title.Size = UDim2.new(1, 0, 0, 35)
Title.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Title.Text = "ACUSADO23 HITBOX"
Title.Font = Enum.Font.GothamBold
Title.TextSize = 14
Title.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", Title).CornerRadius = UDim.new(0, 10)

-- MOTOR RAINBOW
task.spawn(function()
    while true do
        for i = 0, 1, 0.005 do
            local color = Color3.fromHSV(i, 0.8, 1)
            Stroke.Color = color
            Title.TextColor3 = color
            task.wait(0.02)
        end
    end
end)

-- INPUT DE TAMAÑO
local SizeInput = Instance.new("TextBox", Main)
SizeInput.Size = UDim2.new(0.8, 0, 0, 30)
SizeInput.Position = UDim2.new(0.1, 0, 0.35, 0)
SizeInput.Text = "12"
SizeInput.PlaceholderText = "Size"
SizeInput.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
SizeInput.TextColor3 = Color3.fromRGB(255, 255, 255)
SizeInput.Font = Enum.Font.Gotham
Instance.new("UICorner", SizeInput).CornerRadius = UDim.new(0, 6)

-- BOTÓN RUN
_G.Hitbox = false
local RunBtn = Instance.new("TextButton", Main)
RunBtn.Size = UDim2.new(0.8, 0, 0, 35)
RunBtn.Position = UDim2.new(0.1, 0, 0.65, 0)
RunBtn.Text = "ACTIVAR HITBOX"
RunBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
RunBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
RunBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", RunBtn).CornerRadius = UDim.new(0, 6)

RunBtn.MouseButton1Click:Connect(function()
    _G.Hitbox = not _G.Hitbox
    RunBtn.Text = _G.Hitbox and "HITBOX: ON" or "HITBOX: OFF"
    RunBtn.BackgroundColor3 = _G.Hitbox and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(30, 30, 30)
end)

-- LÓGICA HITBOX (SIN LAG Y SIN KICK)
task.spawn(function()
    while task.wait(0.5) do
        if _G.Hitbox then
            local s = tonumber(SizeInput.Text) or 12
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= Players.LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
                    pcall(function()
                        local head = v.Character.Head
                        if head.Size.Y ~= s then
                            head.Size = Vector3.new(s, s, s)
                            head.Transparency = 0.7
                            head.CanCollide = false
                            head.Massless = true
                        end
                    end)
                end
            end
        end
    end
end)
