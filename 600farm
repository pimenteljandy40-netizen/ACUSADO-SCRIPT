Start.MouseButton1Click:Connect(function()
    Farming = true
    Status.Text = "FARM: ACTIVO ✅ (SAFE)"
    Status.TextColor3 = Color3.fromRGB(0, 255, 0)
    task.spawn(function()
        while Farming do
            local ruta = {"Water", "Sugar", "Gelatin", "Bag"}
            for _, v in pairs(ruta) do
                if not Farming then break end
                local obj = workspace:FindFirstChild(v, true)
                if obj then
                    -- SAFE MODE: Movimiento suavizado para evitar kick
                    local player = game.Players.LocalPlayer.Character.HumanoidRootPart
                    player.CFrame = obj.CFrame * CFrame.new(0, 2, 0)
                    task.wait(2.5) 
                    local p = obj:FindFirstChildOfClass("ProximityPrompt")
                    if p then fireproximityprompt(p) end
                end
            end
            task.wait(1.5)
        end
    end)
end)

