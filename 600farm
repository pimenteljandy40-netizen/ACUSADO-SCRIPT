-- Actualizador
task.spawn(function()
    while true do
        local inv = game.Players.LocalPlayer:FindFirstChild("Backpack")
        if inv and HubFrame.Visible then
            local function get(n)
                local c = 0
                for _, item in pairs(inv:GetChildren()) do
                    if item.Name:lower():find(n:lower()) then c = c + 1 end
                end
                return c
            end
            sWater.Text = "Water: "..get("Water")
            sSugar.Text = "Sugar: "..get("Sugar")
            sGela.Text = "Gelatin: "..get("Gelatin")
            sBolsa.Text = "Bag: "..get("Bag")
            sSmall.Text = "Small: "..get("Small")
            sMed.Text = "Medium: "..get("Medium")
            sLarge.Text = "Large: "..get("Large")
            
            if Farming and get("Water") == 0 then 
                Status.Text = "No hay ingredientes ❌" 
                Status.TextColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
        task.wait(1)
    end
end)
