--- LÓGICA ESP ---
local function createESP(player)
    local box = Drawing.new("Square")
    local name = Drawing.new("Text")
    local tracer = Drawing.new("Line")
    local invText = Drawing.new("Text")

    RunService.RenderStepped:Connect(function()
        if espEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= LocalPlayer then
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)

            if onScreen then
                box.Visible = true
                box.Size = Vector2.new(2000 / pos.Z, 3000 / pos.Z)
                box.Position = Vector2.new(pos.X - box.Size.X / 2, pos.Y - box.Size.Y / 2)
                box.Color = THEME_BLUE
                box.Filled = false

                name.Visible = true
                name.Text = player.Name
                name.Position = Vector2.new(pos.X, pos.Y - box.Size.Y / 2 - 15)
                name.Outline = true
                name.Center = true

                tracer.Visible = true
                tracer.From = Vector2.new(Camera.ViewportSize.X / 2, 0)
                tracer.To = Vector2.new(pos.X, pos.Y - box.Size.Y / 2)
                tracer.Color = THEME_BLUE

                local tool = player.Character:FindFirstChildOfClass("Tool")
                invText.Visible = true
                invText.Text = tool and "["..tool.Name.."]" or "[Empty]"
                invText.Position = Vector2.new(pos.X, pos.Y + box.Size.Y / 2 + 5)
                invText.Outline = true
                invText.Center = true
            else
                box.Visible = false; name.Visible = false; tracer.Visible = false; invText.Visible = false
            end
        else
            box.Visible = false; name.Visible = false; tracer.Visible = false; invText.Visible = false
        end
    end)
end

for _, v in pairs(Players:GetPlayers()) do createESP(v) end
Players.PlayerAdded:Connect(createESP)

--- LÓGICA HEADSIZE (SAFE & CREAM) ---
local function applySafe(p)
    pcall(function()
        if p.Character and p.Character:FindFirstChild("Head") then
            local h = p.Character.Head
            h.Size = Vector3.new(currentSize, currentSize, currentSize)
            h.Color = CREAM_COLOR -- Cabeza color crema
            h.CanCollide = false
            h.Massless = true
        end
    end)
end

